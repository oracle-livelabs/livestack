# =============================================================================
# Big Star Collectibles — Parent Container (PinC Architecture)
# Outer shell with Podman pre-installed for orchestrating inner services.
#
# Usage: Build this image when deploying the PinC (Pod-in-Container) model.
#        The parent runs Podman inside the container to orchestrate DB,
#        ORDS, Ollama, and the app as an inner pod.
#
# For local development, use podman-compose directly instead.
# =============================================================================

FROM fedora:41

# Install Podman + compose support
RUN dnf install -y \
    podman \
    podman-compose \
    fuse-overlayfs \
    curl \
    && dnf clean all

# Allow rootless Podman inside the container
RUN echo "hub_user:100000:65536" >> /etc/subuid && \
    echo "hub_user:100000:65536" >> /etc/subgid

# Copy the compose file and application sources
WORKDIR /app
COPY compose.yaml .
COPY Containerfile .
COPY requirements.txt .
COPY init.sql .
COPY seeder.py .
COPY main.py .
COPY templates/ ./templates/

# Entrypoint: start the inner pod via podman-compose
ENTRYPOINT ["podman-compose", "up", "-d"]
