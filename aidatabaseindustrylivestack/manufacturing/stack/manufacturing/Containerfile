FROM docker.io/node:20-bookworm AS frontend-build

WORKDIR /workspace/app/frontend

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./
RUN npm run build

FROM docker.io/node:20-bookworm AS runtime

WORKDIR /workspace/app

ENV NODE_ENV=production \
    PORT=3001

COPY package*.json ./
RUN npm ci --omit=dev && npm cache clean --force

COPY backend ./backend
COPY frontend ./frontend
COPY db ./db
COPY scripts ./scripts
COPY Containerfile .dockerignore compose.yml .env.example ./
COPY --from=frontend-build /workspace/app/frontend/dist ./frontend/dist

EXPOSE 3001

CMD ["npm", "start"]
